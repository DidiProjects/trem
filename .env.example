# ── App ───────────────────────────────────────────────────────────────────
API_KEY=sua-chave-admin-aqui
API_URL=http://localhost:3002
DEBUG=false

# ── Banco de dados ────────────────────────────────────────────────────────
POSTGRES_PASSWORD=senha-segura-aqui
# DATABASE_URL é montado automaticamente no docker-compose
# Para rodar local sem Docker:
# DATABASE_URL=postgresql+asyncpg://trem:senha-segura-aqui@localhost:5432/trem

# ── JWT RS256 — gere com: python scripts/generate_keys.py ─────────────────
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ── Email (SMTP) ──────────────────────────────────────────────────────────
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=seu-email@gmail.com
EMAIL_SMTP_PASSWORD=sua-senha-de-app
EMAIL_RECIPIENT=destinatario-feedback@gmail.com

# ── API Aérea (opcional — mesmo nome de serviço Docker) ───────────────────
AIRLINE_API_URL=http://airline-api:3003
AIRLINE_API_KEY=

# ── Arquivos ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/tmp/uploads
MAX_FILE_SIZE=52428800
